<!DOCTYPE html>
<html>

<head>
    <title>Login - MindTrack</title>
    <link rel="stylesheet" href="/output.css">
</head>

<body class="bg-stone-bg min-h-screen flex items-center justify-center px-6">

    <div class="max-w-md w-full">
        <div class="text-center mb-8">
            <a href="/" class="text-2xl font-bold text-sage-dark tracking-tight">MindTrack</a>
        </div>

        <div class="bg-white p-10 rounded-[2.5rem] shadow-sm border border-gray-100">
            <h2 class="text-2xl font-bold text-charcoal mb-2 text-center">Welcome Back</h2>
            <p class="text-gray-500 text-center mb-8 text-sm">Continue your journey of mindfulness.</p>

            <form action="/login" method="POST" class="space-y-5">
                <% if (locals.error) { %>
                    <div class="bg-red-100 border-l-4 border-red-500 text-red-700 p-4 mb-6 rounded shadow-sm flex items-center shadow-red-100/50"
                        role="alert">
                        <svg class="h-5 w-5 mr-3" fill="currentColor" viewBox="0 0 20 20">
                            <path fill-rule="evenodd"
                                d="M18 10a8 8 0 11-16 0 8 8 0 0116 0zm-7 4a1 1 0 11-2 0 1 1 0 012 0zm-1-9a1 1 0 00-1 1v4a1 1 0 102 0V6a1 1 0 00-1-1z"
                                clip-rule="evenodd" />
                        </svg>
                        <p class="font-bold text-sm">
                            <%= error %>
                        </p>
                    </div>
                    <% } %>
                        <div>
                            <label
                                class="block text-xs font-black uppercase tracking-widest text-gray-400 mb-2 ml-1">Email
                                Address</label>
                            <input type="email" name="email" placeholder="name@example.com" required
                                class="w-full bg-stone-bg border-none p-4 rounded-2xl focus:ring-2 focus:ring-sage-med focus:outline-none placeholder:text-gray-300">
                        </div>

                        <div>
                            <label
                                class="block text-xs font-black uppercase tracking-widest text-gray-400 mb-2 ml-1">Password</label>
                            <input type="password" name="password" placeholder="••••••••" required
                                class="w-full bg-stone-bg border-none p-4 rounded-2xl focus:ring-2 focus:ring-sage-med focus:outline-none placeholder:text-gray-300">
                        </div>

                        <div class="pt-4">
                            <button type="submit"
                                class="w-full bg-sage-dark text-white font-bold py-4 rounded-2xl shadow-lg hover:shadow-xl hover:scale-[1.02] transition-all">
                                Login
                            </button>
                        </div>
            </form>

            <div class="mt-8 pt-6 border-t border-gray-50 text-center">
                <p class="text-gray-500 text-sm">
                    New to MindTrack?
                    <a href="/signup" class="text-sage-dark font-bold hover:underline ml-1">Create an account</a>
                </p>
            </div>
        </div>

        <p class="text-center mt-8 text-gray-400 text-xs">
            © 2026 MindTrack. Simple habits, deeper awareness.
        </p>
    </div>

</body>

</html>