<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <title>Logged Out - MindTrack</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <script>
        tailwind.config = {
            theme: {
                extend: {
                    colors: {
                        'sage-dark': '#4A675A',
                        'stone-bg': '#F2F4F3',
                        'charcoal': '#2D312E'
                    }
                }
            }
        }
    </script>
</head>

<body class="bg-stone-bg min-h-screen flex items-center justify-center p-6">

    <div class="max-w-md w-full bg-white p-10 rounded-[2.5rem] shadow-xl text-center border border-gray-100">
        <div class="w-20 h-20 bg-sage-dark/10 rounded-full flex items-center justify-center mx-auto mb-6">
            <svg class="w-10 h-10 text-sage-dark" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M5 13l4 4L19 7"></path>
            </svg>
        </div>

        <h1 class="text-2xl font-black text-charcoal mb-2">Successfully Logged Out</h1>
        <p class="text-gray-500 mb-8">Thank you for taking time for your mindfulness today. See you soon!</p>

        <div class="flex flex-col gap-3">
            <a href="/login"
                class="bg-sage-dark text-white font-bold py-4 rounded-2xl hover:bg-opacity-90 transition shadow-md">
                Back to Login
            </a>

            <a href="/"
                class="text-sage-dark font-bold py-4 rounded-2xl border-2 border-sage-dark hover:bg-sage-dark/5 transition">
                Back to Homepage
            </a>
        </div>
    </div>

</body>

</html>