<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <title>MindTrack - Find Your Balance</title>
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
</head>

<body class="bg-stone-bg dark:bg-dark-bg text-charcoal dark:text-gray-200 transition-colors duration-300">

    <header
        class="bg-white dark:bg-dark-bg shadow-sm border-b border-gray-200 dark:border-gray-800 relative z-50 transition-colors">
        <div class="max-w-6xl mx-auto px-6 py-4 flex justify-between items-center">
            <a href="/" class="text-2xl font-bold text-sage-dark dark:text-white transition-colors">MindTrack</a>

            <nav class="space-x-8 hidden md:flex items-center">
                <a href="/dashboard"
                    class="font-medium text-charcoal dark:text-gray-300 hover:text-sage-dark transition-colors">Dashboard</a>
                <a href="/habits"
                    class="font-medium text-charcoal dark:text-gray-300 hover:text-sage-dark transition-colors">Habits</a>
                <a href="/mood"
                    class="font-medium text-charcoal dark:text-gray-300 hover:text-sage-dark transition-colors">Mood
                    Check-In</a>
                <a href="/history"
                    class="font-medium text-charcoal dark:text-gray-300 hover:text-sage-dark transition-colors">History</a>

                <div class="flex items-center gap-4 ml-4 border-l pl-4 border-gray-200 dark:border-gray-700">
                    <% if (locals.user) { %>
                        <a href="/logout" class="font-bold text-sage-dark dark:text-sage-med">Logout</a>
                        <% } else { %>
                            <a href="/login"
                                class="text-sage-dark dark:text-sage-med font-semibold hover:underline">Login</a>
                            <a href="/signup" class="bg-sage-dark text-white px-4 py-2 rounded-lg font-bold">Sign Up</a>
                            <% } %>
                                <button id="theme-toggle"
                                    class="p-2 rounded-lg bg-gray-100 dark:bg-gray-700 text-gray-600 dark:text-gray-300 transition-colors">
                                    <span id="theme-toggle-icon">🌙</span>
                                </button>
                </div>
            </nav>

            <div class="md:hidden flex items-center gap-4">
                <button id="theme-toggle-mobile"
                    class="p-2 rounded-lg bg-gray-100 dark:bg-gray-700 text-gray-600 dark:text-gray-300 transition-colors">
                    <span id="theme-toggle-icon-mobile">🌙</span>
                </button>
                <button id="mobile-menu-button" class="text-charcoal dark:text-white focus:outline-none p-2">
                    <svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path id="menu-icon" stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                            d="M4 6h16M4 12h16M4 18h16"></path>
                        <path id="close-icon" class="hidden" stroke-linecap="round" stroke-linejoin="round"
                            stroke-width="2" d="M6 18L18 6M6 6l12 12"></path>
                    </svg>
                </button>
            </div>
        </div>

        <div id="mobile-menu"
            class="hidden md:hidden bg-white dark:bg-dark-bg border-b border-gray-200 dark:border-gray-800 absolute w-full left-0 shadow-xl z-40 transition-colors">
            <nav class="flex flex-col p-6 space-y-4">
                <a href="/dashboard"
                    class="text-lg font-bold text-charcoal dark:text-gray-200 hover:text-sage-dark">Dashboard</a>
                <a href="/habits"
                    class="text-lg font-bold text-charcoal dark:text-gray-200 hover:text-sage-dark">Habits</a>
                <a href="/mood" class="text-lg font-bold text-charcoal dark:text-gray-200 hover:text-sage-dark">Mood
                    Check-In</a>
                <a href="/history"
                    class="text-lg font-bold text-charcoal dark:text-gray-200 hover:text-sage-dark">History</a>
                <div class="pt-4 border-t border-gray-100 dark:border-gray-700 flex flex-col gap-3">
                    <% if (locals.user) { %>
                        <a href="/logout"
                            class="text-center font-bold text-white py-3 rounded-xl bg-sage-dark dark:bg-red-900/20">Logout</a>
                        <% } else { %>
                            <a href="/login"
                                class="text-center font-bold text-sage-dark dark:text-sage-med py-3 border border-sage-dark dark:border-sage-med rounded-xl">Login</a>
                            <a href="/signup" class="text-center font-bold text-white bg-sage-dark py-3 rounded-xl">Sign
                                Up</a>
                            <% } %>
                </div>
            </nav>
        </div>
    </header>

    <section class="min-h-[80vh] flex flex-col justify-center items-center text-center px-6">
        <h1 class="text-4xl md:text-6xl font-extrabold mb-6 tracking-tight text-charcoal dark:text-white">
            Track your habits. <br><span class="text-sage-dark dark:text-sage-med">Nurture your mind.</span>
        </h1>
        <p class="text-lg md:text-xl text-gray-600 dark:text-gray-400 mb-10 max-w-2xl leading-relaxed">
            A calm space to build consistency and emotional balance.
        </p>
        <div class="flex flex-col sm:flex-row gap-4">
            <a href="/dashboard"
                class="bg-sage-dark text-white px-10 py-4 rounded-xl font-bold hover:shadow-lg transition">Go to
                Dashboard</a>
            <a href="/signup"
                class="bg-slate-deep text-white px-10 py-4 rounded-xl font-bold hover:shadow-lg transition">Create
                Account</a>
        </div>
    </section>

    <section class="py-24 bg-sage-dark dark:bg-[#151514] text-white px-6 transition-colors">
        <div class="max-w-5xl mx-auto">
            <div class="text-center mb-16">
                <h2 class="text-3xl md:text-4xl font-bold mb-4">Mindful Features</h2>
                <div class="h-1 w-20 bg-white/30 mx-auto rounded-full"></div>
            </div>
            <div class="grid md:grid-cols-3 gap-10">
                <div
                    class="p-8 bg-white/10 dark:bg-white/5 rounded-2xl border border-white/10 hover:bg-white/15 transition">
                    <h3 class="text-xl font-bold mb-3">Daily Rituals</h3>
                    <p class="text-white/80 leading-relaxed">Small, consistent steps lead to significant change. Track
                        your progress daily.</p>
                </div>
                <div
                    class="p-8 bg-white/10 dark:bg-white/5 rounded-2xl border border-white/10 hover:bg-white/15 transition">
                    <h3 class="text-xl font-bold mb-3">Emotional Clarity</h3>
                    <p class="text-white/80 leading-relaxed">Understand the "why" behind your moods with guided
                        check-ins.</p>
                </div>
                <div
                    class="p-8 bg-white/10 dark:bg-white/5 rounded-2xl border border-white/10 hover:bg-white/15 transition">
                    <h3 class="text-xl font-bold mb-3">Simple Reflection</h3>
                    <p class="text-white/80 leading-relaxed">No noise, no clutter. Just a peaceful interface for your
                        personal growth.</p>
                </div>
            </div>
        </div>
    </section>

    <section class="py-24 bg-white dark:bg-dark-bg px-6 transition-colors">
        <div class="max-w-6xl mx-auto grid md:grid-cols-2 gap-16 items-center">
            <div>
                <h2 class="text-3xl font-bold mb-6 text-charcoal dark:text-white">Why MindTrack?</h2>
                <ul class="space-y-6">
                    <li class="flex gap-4">
                        <span class="text-sage-dark dark:text-sage-med font-bold text-xl">01</span>
                        <p class="text-gray-600 dark:text-gray-400"><strong>Visual Progress:</strong> See your streaks
                            and monthly growth at a glance.</p>
                    </li>
                    <li class="flex gap-4">
                        <span class="text-sage-dark dark:text-sage-med font-bold text-xl">02</span>
                        <p class="text-gray-600 dark:text-gray-400"><strong>Mood History:</strong> Connect your habits
                            to your happiness over time.</p>
                    </li>
                </ul>
            </div>
            <div
                class="bg-stone-bg dark:bg-gray-800 p-10 rounded-3xl border border-gray-100 dark:border-gray-700 shadow-inner">
                <div
                    class="aspect-video bg-sage-med/20 rounded-xl flex items-center justify-center text-sage-dark dark:text-sage-med italic font-serif">
                    "Small daily habits improve your mood over time."
                </div>
            </div>
        </div>
    </section>

    <section class="py-20 bg-stone-bg dark:bg-[#151514] text-center px-6 transition-colors">
        <div
            class="max-w-3xl mx-auto bg-white dark:bg-gray-800 p-12 rounded-[3rem] shadow-xl border border-gray-100 dark:border-gray-700">
            <h2 class="text-3xl font-bold mb-4 text-charcoal dark:text-white">Ready to find your balance?</h2>
            <p class="mb-10 text-gray-500 dark:text-gray-400">Join our community of mindful trackers today.</p>
            <a href="/signup"
                class="inline-block bg-sage-dark text-white px-12 py-4 rounded-2xl font-bold hover:scale-105 transition shadow-lg">Get
                Started for Free</a>
        </div>
    </section>

    <footer class="bg-white dark:bg-dark-bg border-t border-gray-100 dark:border-gray-800 py-12 transition-colors">
        <div class="max-w-6xl mx-auto px-6 flex flex-col md:flex-row justify-between items-center gap-6">
            <p class="font-bold text-sage-dark dark:text-white text-xl">MindTrack</p>
            <p class="text-gray-400 dark:text-gray-300 text-sm">© 2026 MindTrack.</p>
        </div>
    </footer>

    <script src="https://cdn.tailwindcss.com"></script>
    <script>
        tailwind.config = {
            darkMode: 'class',
            theme: {
                extend: {
                    colors: {
                        'sage-dark': '#4A675A',
                        'sage-med': '#708F81',
                        'slate-deep': '#4E657E',
                        'stone-bg': '#F2F4F3',
                        'charcoal': '#2D312E',
                        'dark-bg': '#1c1c1b'
                    }
                }
            }
        }

        // --- Theme Toggle Logic ---
        const themeToggleBtns = [document.getElementById('theme-toggle'), document.getElementById('theme-toggle-mobile')];
        const themeIcons = [document.getElementById('theme-toggle-icon'), document.getElementById('theme-toggle-icon-mobile')];
        const html = document.documentElement;

        function updateThemeUI(isDark) {
            themeIcons.forEach(icon => {
                if (icon) icon.innerText = isDark ? '☀️' : '🌙';
            });
        }

        if (localStorage.getItem('color-theme') === 'dark') {
            html.classList.add('dark');
            updateThemeUI(true);
        }

        themeToggleBtns.forEach(btn => {
            if (btn) {
                btn.addEventListener('click', () => {
                    html.classList.toggle('dark');
                    const isDark = html.classList.contains('dark');
                    updateThemeUI(isDark);
                    localStorage.setItem('color-theme', isDark ? 'dark' : 'light');
                });
            }
        });

        // --- Mobile Menu Toggle Logic ---
        const menuBtn = document.getElementById('mobile-menu-button');
        const mobileMenu = document.getElementById('mobile-menu');
        const menuIcon = document.getElementById('menu-icon');
        const closeIcon = document.getElementById('close-icon');

        if (menuBtn) {
            menuBtn.addEventListener('click', () => {
                mobileMenu.classList.toggle('hidden');
                menuIcon.classList.toggle('hidden');
                closeIcon.classList.toggle('hidden');
            });
        }

        // Close menu if window is resized to desktop size
        window.addEventListener('resize', () => {
            if (window.innerWidth >= 768) {
                mobileMenu.classList.add('hidden');
                menuIcon.classList.remove('hidden');
                closeIcon.classList.add('hidden');
            }
        });
    </script>
</body>

</html>